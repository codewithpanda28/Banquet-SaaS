@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --radius: 0.5rem;

  /* Premium Light Theme (Clean White, Black Text) */
  --background: 0 0% 100%;
  --foreground: 0 0% 0%;
  /* Pure Black */

  --card: 0 0% 100%;
  --card-foreground: 0 0% 0%;

  --popover: 0 0% 100%;
  --popover-foreground: 0 0% 0%;

  --primary: 142 76% 36%;
  /* Professional Green for Actions */
  --primary-foreground: 0 0% 100%;

  --secondary: 0 0% 96%;
  --secondary-foreground: 0 0% 0%;

  --muted: 0 0% 96%;
  --muted-foreground: 0 0% 40%;

  --accent: 142 76% 96%;
  --accent-foreground: 142 76% 36%;

  --destructive: 0 84% 60%;
  --destructive-foreground: 0 0% 100%;

  --border: 0 0% 90%;
  --input: 0 0% 90%;
  --ring: 142 76% 36%;

  --chart-1: 142 76% 36%;
  --chart-2: 0 0% 0%;
  --chart-3: 0 0% 40%;
  --chart-4: 142 76% 45%;
  --chart-5: 0 84% 60%;

  --sidebar-background: 0 0% 98%;
  --sidebar-foreground: 0 0% 40%;
  --sidebar-primary: 142 76% 36%;
  --sidebar-primary-foreground: 0 0% 98%;
  --sidebar-accent: 142 76% 96%;
  --sidebar-accent-foreground: 142 76% 36%;
  --sidebar-border: 0 0% 90%;
  --sidebar-ring: 142 76% 36%;
}

.dark {
  /* Copy of light theme for "Black Text Everywhere" requirement */
  --background: 0 0% 100%;
  --foreground: 0 0% 0%;
  --card: 0 0% 100%;
  --card-foreground: 0 0% 0%;
  --popover: 0 0% 100%;
  --popover-foreground: 0 0% 0%;
  --primary: 142 76% 36%;
  --primary-foreground: 0 0% 100%;
  --secondary: 0 0% 96%;
  --secondary-foreground: 0 0% 0%;
  --muted: 0 0% 96%;
  --muted-foreground: 0 0% 40%;
  --accent: 142 76% 96%;
  --accent-foreground: 142 76% 36%;
  --destructive: 0 62% 30%;
  --destructive-foreground: 0 0% 98%;
  --border: 0 0% 90%;
  --input: 0 0% 90%;
  --ring: 142 76% 36%;

  --sidebar-background: 0 0% 98%;
  --sidebar-foreground: 0 0% 40%;
  --sidebar-primary: 142 76% 36%;
  --sidebar-primary-foreground: 0 0% 98%;
  --sidebar-accent: 142 76% 96%;
  --sidebar-accent-foreground: 142 76% 36%;
  --sidebar-border: 0 0% 90%;
  --sidebar-ring: 142 76% 36%;
}

@layer base {
  * {
    border-color: hsl(var(--border));
    outline-color: hsl(var(--ring));
  }

  body {
    background-color: hsl(var(--background));
    color: hsl(var(--foreground));
  }
}


